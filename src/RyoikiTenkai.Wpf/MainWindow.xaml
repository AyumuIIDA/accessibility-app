<Window x:Class="RyoikiTenkai.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:native="clr-namespace:RyoikiTenkai.Wpf.Native"
        Title="RyoikiTenkai" Height="760" Width="1180"
        MinHeight="680" MinWidth="1040"
        Background="#0F1115">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E7EAF0" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="92" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <CheckBox x:Name="UseNativeRuntimeCheckBox"
                              Content="Native runtime"
                              Foreground="#E7EAF0"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0" />
                    <Button x:Name="StartButton" Content="Start" Click="StartButton_Click" />
                    <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" IsEnabled="False" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="RyoikiTenkai" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Camera -> palm bbox -> hand landmarks -> gesture -> PC action"
                               Foreground="#9DA6B8" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="#050608" BorderBrush="#2B313D" BorderThickness="1" CornerRadius="8">
                <Grid x:Name="PreviewHost" ClipToBounds="True">
                    <Image x:Name="CameraImage" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="-1" />
                        </Image.RenderTransform>
                    </Image>
                    <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5">
                        <Canvas.RenderTransform>
                            <ScaleTransform ScaleX="-1" />
                        </Canvas.RenderTransform>
                    </Canvas>
                    <native:NativeVisionHost x:Name="NativeVisionHostControl" Visibility="Collapsed" />
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14"
                            Padding="10,6" Background="#B0000000" CornerRadius="4">
                        <TextBlock x:Name="OverlayStatusText" Text="Stopped" FontSize="15" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#171B22" Padding="12" Margin="0,0,8,0" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Gesture" Foreground="#9DA6B8" />
                        <TextBlock x:Name="GestureText" Text="-" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#171B22" Padding="12" Margin="0,0,8,0" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Confidence" Foreground="#9DA6B8" />
                        <TextBlock x:Name="ConfidenceText" Text="-" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#171B22" Padding="12" Margin="0,0,8,0" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Latency" Foreground="#9DA6B8" />
                        <TextBlock x:Name="LatencyText" Text="-" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#171B22" Padding="12" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Runtime" Foreground="#9DA6B8" />
                        <TextBlock Text="ONNX Runtime CPU" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" Margin="16,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#171B22" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Execution State" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="StateText" Text="Idle" Margin="0,8,0,0" FontSize="16" />
                    <TextBlock Text="Stable frames: 3 / Cooldown: 1500 ms" Foreground="#9DA6B8" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#171B22" Padding="14" Margin="0,12" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="130" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Bindings" FontSize="18" FontWeight="SemiBold" />
                    <ListBox x:Name="BindingsList" Grid.Row="1" Margin="0,8,0,12" Background="#0F1115" Foreground="#E7EAF0" />

                    <TextBlock Grid.Row="2" Text="Action Log" FontSize="18" FontWeight="SemiBold" />
                    <ListBox x:Name="ActionLogList" Grid.Row="3" Margin="0,8,0,0" Background="#0F1115" Foreground="#E7EAF0" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#171B22" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Register Action" FontSize="18" FontWeight="SemiBold" />

                    <TextBlock Text="Gesture" Foreground="#9DA6B8" Margin="0,12,0,0" />
                    <ComboBox x:Name="GestureCombo">
                        <ComboBoxItem Content="open_palm" IsSelected="True" />
                        <ComboBoxItem Content="fist" />
                        <ComboBoxItem Content="pinch" />
                        <ComboBoxItem Content="peace" />
                    </ComboBox>

                    <TextBlock Text="Action" Foreground="#9DA6B8" />
                    <ComboBox x:Name="ActionTypeCombo" SelectionChanged="ActionTypeCombo_SelectionChanged">
                        <ComboBoxItem Content="Launch app" IsSelected="True" Tag="app.launch" />
                        <ComboBoxItem Content="Hotkey" Tag="keyboard.hotkey" />
                        <ComboBoxItem Content="Type text" Tag="keyboard.typeText" />
                    </ComboBox>

                    <TextBlock x:Name="ActionValueLabel" Text="Path" Foreground="#9DA6B8" />
                    <TextBox x:Name="ActionValueText" Text="notepad.exe" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save Binding" Click="SaveBindingButton_Click" />
                        <Button Content="Reset Sample" Click="ResetSampleButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
